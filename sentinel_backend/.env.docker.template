# Docker Environment Template
# This file is used for Docker Compose deployments
# Secrets should be loaded from Vault or Docker secrets

# =============================================================================
# Vault Configuration
# =============================================================================
VAULT_ADDR=http://vault:8200
VAULT_ROLE_ID=${VAULT_ROLE_ID}
VAULT_SECRET_ID=${VAULT_SECRET_ID}

# =============================================================================
# Application Configuration
# =============================================================================
SENTINEL_ENVIRONMENT=${SENTINEL_ENVIRONMENT:-development}
SENTINEL_APP_DEBUG=${SENTINEL_APP_DEBUG:-false}
SENTINEL_APP_LOG_LEVEL=${SENTINEL_APP_LOG_LEVEL:-INFO}

# =============================================================================
# LLM Configuration
# =============================================================================
SENTINEL_APP_LLM_PROVIDER=${SENTINEL_APP_LLM_PROVIDER:-anthropic}
SENTINEL_APP_LLM_MODEL=${SENTINEL_APP_LLM_MODEL:-claude-sonnet-4}

# LLM API keys loaded from Vault at runtime
# Services will fetch from: vault kv get secret/sentinel/${ENVIRONMENT}/llm

# =============================================================================
# Database Configuration (Loaded from Vault)
# =============================================================================
# Services will fetch from: vault kv get secret/sentinel/${ENVIRONMENT}/database

# =============================================================================
# Message Broker Configuration (Loaded from Vault)
# =============================================================================
# Services will fetch from: vault kv get secret/sentinel/${ENVIRONMENT}/broker

# =============================================================================
# Security Configuration (Loaded from Vault)
# =============================================================================
# Services will fetch from: vault kv get secret/sentinel/${ENVIRONMENT}/auth
SENTINEL_SECURITY_CORS_ORIGINS=["http://localhost:3000"]

# =============================================================================
# Network Configuration
# =============================================================================
SENTINEL_NETWORK_API_GATEWAY_PORT=8000
SENTINEL_NETWORK_AUTH_SERVICE_PORT=8005
SENTINEL_NETWORK_SPEC_SERVICE_PORT=8001
SENTINEL_NETWORK_ORCHESTRATION_SERVICE_PORT=8002
SENTINEL_NETWORK_EXECUTION_SERVICE_PORT=8003
SENTINEL_NETWORK_NETWORK_DATA_SERVICE_PORT=8004
