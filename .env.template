# Sentinel API Testing Platform Environment Configuration Template
# Copy this file to .env and fill in with actual values
# NEVER commit .env files with secrets to version control

# =============================================================================
# Vault Configuration (Required for production)
# =============================================================================

# Vault server address
VAULT_ADDR=http://localhost:8200

# Service authentication (AppRole)
# Get these from: ./scripts/secrets-init.sh output
VAULT_ROLE_ID=<set-from-approle-credentials>
VAULT_SECRET_ID=<set-from-approle-credentials>

# =============================================================================
# LLM Provider Configuration
# =============================================================================

# Primary LLM Provider (anthropic, openai, google, mistral, ollama, vllm, none)
SENTINEL_APP_LLM_PROVIDER=anthropic
SENTINEL_APP_LLM_MODEL=claude-sonnet-4

# LLM Generation Parameters
SENTINEL_APP_LLM_TEMPERATURE=0.7
SENTINEL_APP_LLM_MAX_TOKENS=2000
SENTINEL_APP_LLM_TOP_P=1.0
SENTINEL_APP_LLM_TIMEOUT=60
SENTINEL_APP_LLM_MAX_RETRIES=3

# API Keys - Store in Vault, not here!
# Use: vault kv put secret/sentinel/development/llm anthropic_api_key="sk-ant-..."
# SENTINEL_APP_ANTHROPIC_API_KEY=<from-vault>
# SENTINEL_APP_OPENAI_API_KEY=<from-vault>
# SENTINEL_APP_GOOGLE_API_KEY=<from-vault>
# SENTINEL_APP_MISTRAL_API_KEY=<from-vault>

# Fallback Configuration
SENTINEL_APP_LLM_FALLBACK_ENABLED=true

# Caching & Cost Tracking
SENTINEL_APP_LLM_CACHE_ENABLED=true
SENTINEL_APP_LLM_CACHE_TTL=3600
SENTINEL_APP_LLM_COST_TRACKING_ENABLED=true
SENTINEL_APP_LLM_COST_ALERT_THRESHOLD=10.0

# =============================================================================
# Application Configuration
# =============================================================================

SENTINEL_ENVIRONMENT=development
SENTINEL_APP_DEBUG=true
SENTINEL_APP_LOG_LEVEL=INFO

# =============================================================================
# Database Configuration
# =============================================================================

# Database credentials - Loaded from Vault
# Use: vault kv get secret/sentinel/development/database
# SENTINEL_DB_URL=<from-vault>
SENTINEL_DB_POOL_SIZE=10
SENTINEL_DB_MAX_OVERFLOW=20

# =============================================================================
# Security Configuration
# =============================================================================

# JWT settings - Loaded from Vault
# Use: vault kv get secret/sentinel/development/auth
# SENTINEL_SECURITY_JWT_SECRET_KEY=<from-vault>
SENTINEL_SECURITY_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]

# =============================================================================
# Service Configuration
# =============================================================================

SENTINEL_NETWORK_API_GATEWAY_PORT=8000
SENTINEL_NETWORK_AUTH_SERVICE_PORT=8005
SENTINEL_NETWORK_SPEC_SERVICE_PORT=8001
SENTINEL_NETWORK_ORCHESTRATION_SERVICE_PORT=8002
SENTINEL_NETWORK_EXECUTION_SERVICE_PORT=8003
SENTINEL_NETWORK_DATA_SERVICE_PORT=8004

# =============================================================================
# Feature Flags
# =============================================================================

SENTINEL_APP_ENABLE_ANALYTICS=true
SENTINEL_APP_ENABLE_PERFORMANCE_TESTING=true
SENTINEL_APP_ENABLE_SECURITY_TESTING=true
SENTINEL_APP_ENABLE_DATA_MOCKING=true

# =============================================================================
# Agent Configuration
# =============================================================================

SENTINEL_APP_MAX_CONCURRENT_AGENTS=10
SENTINEL_APP_AGENT_TIMEOUT_SECONDS=300
SENTINEL_APP_MAX_TEST_CASES_PER_SPEC=1000

# =============================================================================
# Local Development Only
# =============================================================================

# For local development without Vault, you can set secrets here
# WARNING: Never use this in staging or production!
# USE_LOCAL_SECRETS=false  # Set to true to bypass Vault (dev only)
